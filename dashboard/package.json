    "prettier": "^3.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0",
    "vitest": "^3.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "jsdom": "^26.0.0",
    "msw": "^2.7.0",
    "orval": "^7.0.0",
    "@hey-api/openapi-ts": "^0.1.0"
  },
  "msw": {
    "workerDirectory": ["public"]
